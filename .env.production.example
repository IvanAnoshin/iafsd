# Friendscape production env template.
# Copy to .env.production on the server and replace every CHANGE_ME value.
# The project intentionally does not collect email or phone numbers.

NODE_ENV=production
APP_ENV=production
APP_RELEASE_CHANNEL=production
APP_VERSION_TAG=v0.0.0
RELEASE_REQUIRE_CLEAN_GIT=true
RELEASE_BACKUP_BEFORE_MIGRATE=true
RELEASE_SMOKE_AFTER_DEPLOY=true
DATABASE_URL="postgresql://friendscape_app:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/friendscape?schema=public"
APP_PUBLIC_URL="https://friendscape.example.com"
HOST=0.0.0.0
PORT=3000

# Cookies / CSRF
SESSION_COOKIE_NAME="fs_session"
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE="lax"
CSRF_COOKIE_NAME="fs_csrf"
CSRF_TRUSTED_ORIGINS="https://friendscape.example.com"

# Admin access. Fill after creating the first admin account.
ADMIN_USER_IDS=
ADMIN_USER_KEYS=

# Account recovery without email/phone.
RECOVERY_SESSION_TTL_MINUTES=20
RECOVERY_SECRET_PROMPT="Введи свой секретный ответ"
DEVICE_TRUST_AFTER_SESSIONS=3

# Passkey / WebAuthn. RP_ID is the bare domain, origin includes https://.
PASSKEY_RP_NAME="Friendscape"
PASSKEY_RP_ID="friendscape.example.com"
PASSKEY_ORIGIN="https://friendscape.example.com"
PASSKEY_ALLOWED_ORIGINS="https://friendscape.example.com"
PASSKEY_USER_VERIFICATION="preferred"

# Shared S3-compatible object storage. Use Cloudflare R2, Yandex Object Storage, MinIO, AWS S3, etc.
STORAGE_PROVIDER=s3-compatible
STORAGE_ENDPOINT="https://CHANGE_ME_STORAGE_ENDPOINT"
STORAGE_BUCKET="friendscape-prod"
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID="CHANGE_ME_ACCESS_KEY"
STORAGE_SECRET_ACCESS_KEY="CHANGE_ME_SECRET_KEY"
STORAGE_PUBLIC_BASE_URL="https://cdn.friendscape.example.com"
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PRIVATE=true
STORAGE_SIGNED_READ_TTL_SECONDS=300
STORAGE_USER_DAILY_BYTES=536870912
STORAGE_SCOPE_DAILY_BYTES=2147483648
STORAGE_CACHE_CONTROL="private, max-age=31536000, immutable"

# Chat media: keep private in production.
CHAT_MEDIA_ENABLED=true
CHAT_MEDIA_STORAGE=s3-compatible
CHAT_MEDIA_ALLOW_LOCAL_IN_PRODUCTION=false
CHAT_MEDIA_IMAGE_MAX_BYTES=12582912
CHAT_MEDIA_VIDEO_MAX_BYTES=83886080
CHAT_MEDIA_FILE_MAX_BYTES=41943040
CHAT_MEDIA_VOICE_MAX_BYTES=16777216
CHAT_MEDIA_VIDEO_NOTE_MAX_BYTES=33554432
CHAT_MEDIA_STRIP_JPEG_EXIF=true
CHAT_MEDIA_PREVIEWS_ENABLED=true
CHAT_MEDIA_PREVIEWS_MODE=svg-poster
CHAT_MEDIA_PRIVATE=true
CHAT_MEDIA_SIGNED_READ_TTL_SECONDS=300
CHAT_MEDIA_USER_DAILY_BYTES=536870912
CHAT_MEDIA_SCOPE_DAILY_BYTES=2147483648
CHAT_MEDIA_CACHE_CONTROL="private, max-age=31536000, immutable"
CHAT_MEDIA_ENDPOINT=
CHAT_MEDIA_BUCKET=
CHAT_MEDIA_REGION=auto
CHAT_MEDIA_ACCESS_KEY_ID=
CHAT_MEDIA_SECRET_ACCESS_KEY=
CHAT_MEDIA_PUBLIC_BASE_URL=
CHAT_MEDIA_S3_FORCE_PATH_STYLE=true

# Post media
POST_MEDIA_ENABLED=true
POST_MEDIA_STORAGE=s3-compatible
POST_MEDIA_ALLOW_LOCAL_IN_PRODUCTION=false
POST_MEDIA_IMAGE_MAX_BYTES=12582912
POST_MEDIA_VIDEO_MAX_BYTES=83886080
POST_MEDIA_STRIP_JPEG_EXIF=true
POST_MEDIA_PREVIEWS_ENABLED=true
POST_MEDIA_PREVIEWS_MODE=svg-poster
POST_MEDIA_PRIVATE=true
POST_MEDIA_SIGNED_READ_TTL_SECONDS=300
POST_MEDIA_USER_DAILY_BYTES=536870912
POST_MEDIA_SCOPE_DAILY_BYTES=2147483648
POST_MEDIA_CACHE_CONTROL="private, max-age=31536000, immutable"
POST_MEDIA_ENDPOINT=
POST_MEDIA_BUCKET=
POST_MEDIA_REGION=auto
POST_MEDIA_ACCESS_KEY_ID=
POST_MEDIA_SECRET_ACCESS_KEY=
POST_MEDIA_PUBLIC_BASE_URL=
POST_MEDIA_S3_FORCE_PATH_STYLE=true

# Community media
COMMUNITY_MEDIA_ENABLED=true
COMMUNITY_MEDIA_STORAGE=s3-compatible
COMMUNITY_MEDIA_ALLOW_LOCAL_IN_PRODUCTION=false
COMMUNITY_MEDIA_IMAGE_MAX_BYTES=12582912
COMMUNITY_MEDIA_VIDEO_MAX_BYTES=83886080
COMMUNITY_MEDIA_STRIP_JPEG_EXIF=true
COMMUNITY_MEDIA_THUMBNAILS_ENABLED=true
COMMUNITY_MEDIA_THUMBNAILS_MODE=svg-poster
COMMUNITY_MEDIA_PREVIEWS_ENABLED=true
COMMUNITY_MEDIA_PREVIEWS_MODE=svg-poster
COMMUNITY_MEDIA_PRIVATE=true
COMMUNITY_MEDIA_SIGNED_READ_TTL_SECONDS=300
COMMUNITY_MEDIA_USER_DAILY_BYTES=536870912
COMMUNITY_MEDIA_SCOPE_DAILY_BYTES=2147483648
COMMUNITY_MEDIA_CACHE_CONTROL="private, max-age=31536000, immutable"
COMMUNITY_MEDIA_ENDPOINT=
COMMUNITY_MEDIA_BUCKET=
COMMUNITY_MEDIA_REGION=auto
COMMUNITY_MEDIA_ACCESS_KEY_ID=
COMMUNITY_MEDIA_SECRET_ACCESS_KEY=
COMMUNITY_MEDIA_PUBLIC_BASE_URL=
COMMUNITY_MEDIA_S3_FORCE_PATH_STYLE=true

# Stories media
STORY_MEDIA_ENABLED=true
STORY_MEDIA_STORAGE=s3-compatible
STORY_MEDIA_ALLOW_LOCAL_IN_PRODUCTION=false
STORY_MEDIA_IMAGE_MAX_BYTES=12582912
STORY_MEDIA_VIDEO_MAX_BYTES=83886080
STORY_MEDIA_STRIP_JPEG_EXIF=true
STORY_MEDIA_PREVIEWS_ENABLED=true
STORY_MEDIA_PREVIEWS_MODE=svg-poster
STORY_MEDIA_PRIVATE=true
STORY_MEDIA_SIGNED_READ_TTL_SECONDS=300
STORY_MEDIA_USER_DAILY_BYTES=536870912
STORY_MEDIA_SCOPE_DAILY_BYTES=2147483648
STORY_MEDIA_CACHE_CONTROL="private, max-age=31536000, immutable"
STORY_MEDIA_ENDPOINT=
STORY_MEDIA_BUCKET=
STORY_MEDIA_REGION=auto
STORY_MEDIA_ACCESS_KEY_ID=
STORY_MEDIA_SECRET_ACCESS_KEY=
STORY_MEDIA_PUBLIC_BASE_URL=
STORY_MEDIA_S3_FORCE_PATH_STYLE=true
STORY_MEDIA_CLEANUP_STALE_HOURS=72

# Chat calls / WebRTC. TURN is strongly recommended before public launch.
CHAT_CALLS_ENABLED=1
WEBRTC_PROVIDER=native
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
WEBRTC_TURN_URLS=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=

# Chat anti-spam / safety windows
CHAT_RATE_LIMIT_CONVERSATION_WINDOW_MS=12000
CHAT_RATE_LIMIT_CONVERSATION_BURST=6
CHAT_RATE_LIMIT_GLOBAL_WINDOW_MS=60000
CHAT_RATE_LIMIT_GLOBAL_BURST=20
CHAT_RATE_LIMIT_DUPLICATE_WINDOW_MS=120000
CHAT_RATE_LIMIT_DUPLICATE_BURST=3
CHAT_SAFETY_FLAG_DEDUPE_WINDOW_MS=21600000
CHAT_SAFETY_REPORT_WINDOW_MS=86400000

# Anti-abuse / rate limits. Keep false in production: DB outage should fail closed.
RATE_LIMIT_CLEANUP_OLDER_THAN_HOURS=48
RATE_LIMIT_MEMORY_FALLBACK_IN_PRODUCTION=false

# Build metadata, optional.
APP_GIT_SHA=
APP_BUILD_TIME=

# Backup / restore / cleanup ops
BACKUP_DIR=/var/backups/friendscape/db
BACKUP_RETENTION_DAYS=14
BACKUP_PRUNE_AFTER_SUCCESS=true
BACKUP_NAME_PREFIX=friendscape-prod-db
PG_DUMP_BIN=pg_dump
PG_RESTORE_BIN=pg_restore
PSQL_BIN=psql
NOTIFICATION_CLEANUP_READ_DAYS=90
ABUSE_EVENT_CLEANUP_DAYS=90
AUDIT_LOG_CLEANUP_DAYS=365
DFSN_SESSION_CLEANUP_DAYS=180
CHAT_DRAFT_CLEANUP_DAYS=30

# v86 smoke/e2e checks. Prefer staging, not live production data.
FRIENDSCAPE_SMOKE_BASE_URL=https://staging.example.com
FRIENDSCAPE_SMOKE_PASSWORD=ChangeThisSmokePassword123!
FRIENDSCAPE_SMOKE_PREFIX=
FRIENDSCAPE_E2E_BASE_URL=https://staging.example.com
FRIENDSCAPE_E2E_SKIP_WEB_SERVER=1

# Account deletion self-service
ACCOUNT_DELETION_GRACE_DAYS=14

# Monitoring / logging / alerting
APP_SERVICE_NAME=friendscape
LOG_LEVEL=info
LOG_FORMAT=json
LOG_ERROR_STACKS=false
HEALTH_CHECK_TIMEOUT_MS=3500
MONITORING_BASE_URL=https://example.com
MONITORING_HEALTH_URL=
MONITORING_HTTP_TIMEOUT_MS=5000
MONITORING_DISK_PATH=/var/www/friendscape-next
MONITORING_MIN_FREE_DISK_PERCENT=10
MONITORING_BACKUP_MAX_AGE_HOURS=30
MONITORING_LOG_FILE=/var/log/friendscape/app.log
MONITORING_5XX_THRESHOLD=20
MONITORING_5XX_WINDOW_MINUTES=5

# Realtime transport. Postgres LISTEN/NOTIFY lets multiple Node processes share events.
REALTIME_TRANSPORT=postgres
REALTIME_PG_CHANNEL=friendscape_realtime
REALTIME_HISTORY_LIMIT=250
REALTIME_EVENT_RETENTION_DAYS=3
REALTIME_ALLOW_MEMORY_IN_PRODUCTION=false

# v95 media reference security. Production is strict automatically; keep true for explicitness.
MEDIA_REFERENCE_STRICT=true
