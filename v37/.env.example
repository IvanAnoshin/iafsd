DATABASE_URL="postgresql://friendscape_app:qawsedrftgyh@localhost:5432/fsdb?schema=public"
SHADOW_DATABASE_URL="postgresql://friendscape_app:qawsedrftgyh@localhost:5432/fsdb_shadow?schema=public"
APP_PUBLIC_URL="https://example.com"
SESSION_COOKIE_NAME="fs_session"
SESSION_COOKIE_SECURE="true"
SESSION_COOKIE_SAME_SITE="lax"

# CSRF protection
CSRF_COOKIE_NAME=fs_csrf
CSRF_TRUSTED_ORIGINS=

# Admin access
ADMIN_USER_IDS=
ADMIN_USER_KEYS=

# Recovery flow
RECOVERY_SESSION_TTL_MINUTES=20
RECOVERY_SECRET_PROMPT="Введи свой секретный ответ"

DEVICE_TRUST_AFTER_SESSIONS=3
HOST=0.0.0.0
PORT=3000
# Chat media
CHAT_MEDIA_ENABLED=true
CHAT_MEDIA_STORAGE=local
CHAT_MEDIA_IMAGE_MAX_BYTES=12582912
CHAT_MEDIA_VIDEO_MAX_BYTES=83886080
CHAT_MEDIA_FILE_MAX_BYTES=41943040
CHAT_MEDIA_VOICE_MAX_BYTES=16777216
CHAT_MEDIA_VIDEO_NOTE_MAX_BYTES=33554432

# Chat anti-spam / safety windows
CHAT_RATE_LIMIT_CONVERSATION_WINDOW_MS=12000
CHAT_RATE_LIMIT_CONVERSATION_BURST=6
CHAT_RATE_LIMIT_GLOBAL_WINDOW_MS=60000
CHAT_RATE_LIMIT_GLOBAL_BURST=20
CHAT_RATE_LIMIT_DUPLICATE_WINDOW_MS=120000
CHAT_RATE_LIMIT_DUPLICATE_BURST=3
CHAT_SAFETY_FLAG_DEDUPE_WINDOW_MS=21600000
CHAT_SAFETY_REPORT_WINDOW_MS=86400000

CHAT_CALLS_ENABLED=1
WEBRTC_PROVIDER=native
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
WEBRTC_TURN_URLS=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=
