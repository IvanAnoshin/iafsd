{
  "name": "friendscape-next",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "node scripts/dev-with-prisma.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:push": "node scripts/prisma-push-dev.mjs",
    "prisma:sync": "npm run prisma:generate && npm run prisma:push",
    "check:env": "node scripts/check-env.mjs",
    "prepare:prod": "node scripts/prepare-prod.mjs",
    "build:prod": "npm run prepare:prod && next build",
    "start:prod": "node scripts/start-prod.mjs",
    "verify:launch": "node scripts/verify-launch.mjs",
    "audit:placeholders": "node scripts/audit-placeholders.mjs",
    "cleanup:community-media": "node scripts/cleanup-community-media.mjs",
    "cleanup:community-media:delete": "node scripts/cleanup-community-media.mjs --delete",
    "cleanup:media": "node scripts/cleanup-media.mjs",
    "cleanup:media:delete": "node scripts/cleanup-media.mjs --delete",
    "cleanup:media:object": "node scripts/cleanup-media.mjs --object",
    "cleanup:media:object:delete": "node scripts/cleanup-media.mjs --object --delete",
    "cleanup:rate-limits": "node scripts/cleanup-rate-limits.mjs",
    "audit:access-control": "node scripts/audit-access-control.mjs",
    "audit:sensitive-routes": "node scripts/audit-sensitive-routes.mjs",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "deploy:migrate": "node scripts/migrate-prod.mjs",
    "verify:prod": "npm run check:env && npm run audit:access-control && npm run audit:sensitive-routes && npm run audit:placeholders && npm run security:check && npm run verify:launch",
    "backup:db": "node scripts/backup-db.mjs",
    "backup:db:dry-run": "node scripts/backup-db.mjs --dry-run",
    "backup:db:prune": "node scripts/backup-db.mjs --prune",
    "restore:db": "node scripts/restore-db.mjs",
    "cleanup:expired": "node scripts/cleanup-expired-data.mjs",
    "cleanup:expired:delete": "node scripts/cleanup-expired-data.mjs --delete",
    "cleanup:rate-limits:delete": "node scripts/cleanup-rate-limits.mjs --delete",
    "cleanup:ops": "node scripts/cleanup-ops.mjs",
    "cleanup:ops:delete": "node scripts/cleanup-ops.mjs --delete",
    "smoke:e2e": "node scripts/smoke-e2e.mjs",
    "test:e2e": "playwright test",
    "test:e2e:pages": "playwright test tests/smoke/pages.spec.js",
    "qa:alpha": "node scripts/alpha-qa.mjs",
    "account:deletions": "node scripts/process-account-deletions.mjs",
    "account:deletions:delete": "node scripts/process-account-deletions.mjs --delete",
    "monitor:alerts": "node scripts/check-monitoring-alerts.mjs",
    "monitor:alerts:strict": "node scripts/check-monitoring-alerts.mjs --strict",
    "realtime:check": "node scripts/check-realtime-scaling.mjs",
    "storage:check": "node scripts/check-storage-hardening.mjs",
    "performance:check": "node scripts/check-performance-pass.mjs",
    "accessibility:check": "node scripts/check-accessibility-responsive.mjs",
    "security:check": "node scripts/check-security-pass.mjs",
    "check:staging": "node scripts/check-env.mjs --env-file=.env.staging.example",
    "release:check": "node scripts/check-release-pipeline.mjs",
    "release:staging": "node scripts/release-check.mjs --target=staging --env-file=.env.staging.example",
    "release:prod": "node scripts/release-check.mjs --target=production --env-file=.env.production.example",
    "release:prod:strict": "node scripts/release-check.mjs --target=production --env-file=.env.production --strict",
    "rollback:check": "node scripts/rollback-check.mjs",
    "beta:qa": "node scripts/public-beta-qa.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.2",
    "next": "16.2.3",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.3",
    "prisma": "^7.7.0",
    "@playwright/test": "^1.52.0"
  }
}
